# Copy to `.env` for local development. Never commit real secrets.

# Optional market/news keys
INDIANAPI_API_KEY=
NEWSDATA_API_KEY=
THENEWSAPI_API_KEY=
GNEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Publisher + data storage
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_BUCKET=quantoracle-artifacts
SUPABASE_SERVICE_ROLE_KEY=
QUANTORACLE_EOD_PREFIX=eod/nifty50
QUANTORACLE_SUPABASE_QUOTES_URL=
QUANTORACLE_SUPABASE_EOD_LATEST_URL=
QUANTORACLE_SNAPSHOT_STALE_MINUTES=180
QUANTORACLE_NEWS_PREFIX=news/intel
QUANTORACLE_NEWS_INTEL_URL=
QUANTORACLE_NEWS_STALE_MINUTES=2160

# Provider chain (auto mode)
UPSTOX_ACCESS_TOKEN=
UPSTOX_SYMBOL_MAP=
UPSTOX_SYMBOL_MAP_FILE=
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=
FINNHUB_API_KEY=
EODHD_API_KEY=
GROWW_API_KEY=
GROWW_API_SECRET=

# Workspace billing + plan cards
QUANTORACLE_WORKSPACE_ID=default
QUANTORACLE_WORKSPACE_PLAN=starter
QUANTORACLE_BILLING_TOKEN=
QUANTORACLE_BILLING_REQUIRE_AUTH=0
QUANTORACLE_BILLING_STORE_PATH=data/billing/workspaces.json
QUANTORACLE_BILLING_STORE_JSON=

# Web app env (Vercel)
NEXT_PUBLIC_WORKSPACE_ID=default

# Stadia Maps (basemap)
# Get API key from https://client.stadiamaps.com/
STADIA_MAPS_API_KEY=
NEXT_PUBLIC_MAP_STYLE_URL=

# Clerk Authentication
# Get these from https://clerk.com - Applications > Your App > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
